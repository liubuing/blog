{
  "name": "liveforcode-blog",
  "type": "module",
  "version": "1.0.0",
  "description": "A personal blog built with Astro, inspired by Hexo LiveForCode theme.",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build && pagefind --site dist",
    "postbuild": "pagefind --site dist",
    "preview": "npm run build && wrangler dev",
    "astro": "astro",
    "new": "node scripts/new-post.mjs",
    "deploy": "npm run build && wrangler deploy",
    "cf-typegen": "wrangler types"
  },
  "dependencies": {
    "@astrojs/cloudflare": "11",
    "@astrojs/mdx": "^3.1.7",
    "@astrojs/rss": "^4.0.9",
    "@astrojs/sitemap": "3.2.1",
    "@astrojs/tailwind": "^5.1.2",
    "astro": "^4.16.13",
    "pagefind": "^1.1.1",
    "tailwindcss": "^3.4.14"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "wrangler": "^4.107.0"
  }
}

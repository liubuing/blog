---
import BaseLayout from './BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import type { Post } from '@/utils';

export interface Props {
  title: string;
  subtitle?: string;
  posts: Post[];
  hero?: boolean;
}
const { title, subtitle, posts, hero = false } = Astro.props;
---
<BaseLayout title={title} description={subtitle}>
  {hero && <span id="top" class="block h-16"></span>}
  <div class="container-prose py-12">
    <div class="mb-10 text-center">
      <h1 class="text-4xl font-bold font-serif">{title}</h1>
      {subtitle && <p class="mt-3 text-ink-light/60 dark:text-ink-dark/60">{subtitle}</p>}
      <div class="mx-auto mt-4 h-1 w-16 rounded-full bg-accent"></div>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {posts.map((post) => <PostCard post={post} />)}
    </div>
    {posts.length === 0 && (
      <p class="py-20 text-center text-ink-light/40 dark:text-ink-dark/40">这里还没有内容~</p>
    )}
  </div>
</BaseLayout>

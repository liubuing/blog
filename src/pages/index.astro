---
import BaseLayout from '@/layouts/BaseLayout.astro';
import Hero from '@/components/Hero.astro';
import PostCard from '@/components/PostCard.astro';
import Icon from '@/components/Icon.astro';
import { getAllPosts, getAllTags, getAllCategories, type Post } from '@/utils';

const posts = await getAllPosts();
const pinned = posts.filter((p) => p.data.pinned).slice(0, 1);
const latest = posts.filter((p) => !pinned.includes(p)).slice(0, 6);
const tags = getAllTags(posts).slice(0, 12);
const categories = getAllCategories(posts);
---
<BaseLayout>
  <Hero />
  <span id="latest"></span>
  <section class="container-prose py-16">
    {pinned.length > 0 && (
      <div class="mb-12">
        <h2 class="mb-4 flex items-center gap-2 font-serif text-2xl font-bold">
          <Icon name="pin" size={22} class="text-accent" /> 置顶文章
        </h2>
        <PostCard post={pinned[0]} featured />
      </div>
    )}

    <div class="mb-8 flex items-end justify-between">
      <h2 class="flex items-center gap-2 font-serif text-2xl font-bold">
        <span class="h-6 w-1 rounded bg-accent"></span> 最新文章
      </h2>
      <a href="/archive/" class="btn-ghost text-sm">查看全部 <Icon name="chevron-right" size={16} /></a>
    </div>
    <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
      {latest.map((post: Post) => <PostCard post={post} />)}
    </div>

    <!-- Categories + Tags overview -->
    <div class="mt-16 grid gap-8 md:grid-cols-3">
      <div class="md:col-span-1">
        <h3 class="mb-4 flex items-center gap-2 font-serif text-lg font-bold">
          <Icon name="folder" size={18} class="text-accent" /> 分类
        </h3>
        <div class="flex flex-wrap gap-2">
          {categories.map((c) => (
            <a href={`/categories/${c.category}/`} class="tag-chip">{c.category} ({c.count})</a>
          ))}
        </div>
      </div>
      <div class="md:col-span-2">
        <h3 class="mb-4 flex items-center gap-2 font-serif text-lg font-bold">
          <Icon name="tag" size={18} class="text-accent" /> 标签云
        </h3>
        <div class="flex flex-wrap gap-2">
          {tags.map(({ tag, count }) => (
            <a href={`/tags/${tag}/`} class="tag-chip text-[0.8rem]" style={`font-size:${0.75 + Math.min(count, 6) * 0.06}rem`}>#{tag} <span class="opacity-50">{count}</span></a>
          ))}
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

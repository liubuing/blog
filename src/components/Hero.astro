---
import { SITE } from '@/consts';
import Icon from './Icon.astro';
const images = SITE.heroImages;
const pv = SITE.characterPV;
const pvEmbedUrl = `https://player.bilibili.com/player.html?bvid=${pv.bvid}&page=1&high_quality=1&danmaku=1&as_wide=1&autoplay=1`;

// 响应式图片:支持 -768w / -1200w / -2048w 后缀的图片自动生成多档
// 输入可以是 fuxuan-3.webp 或 fuxuan-3-2048w.webp,统一规整为 fuxuan-3
const responsiveSrcset = (src) => {
  const m = src.match(/^(.*?)(-\d+w)?\.(\w+)$/);
  if (!m) return null;
  const [, base, , ext] = m;
  if (ext !== 'webp') return null;
  return `${base}-768w.webp 768w, ${base}-1200w.webp 1200w, ${base}-2048w.webp 2048w`;
};
---
<section class="hero-section relative flex min-h-screen items-center justify-center overflow-hidden">

  <!-- 柔和粉紫渐变背景层 -->
  <div class="hero-gradient absolute inset-0"></div>

  <!-- 漂浮光斑(可爱氛围) -->
  <div class="pointer-events-none absolute inset-0 overflow-hidden">
    {Array.from({ length: 14 }).map((_, i) => (
      <span
        class="hero-bubble absolute rounded-full"
        style={`--i:${i}; left:${(i * 7.3) % 100}%; top:${(i * 13.7) % 100}%; animation-delay:${i * 0.8}s;`}
      ></span>
    ))}
  </div>

  <!-- 符玄立绘层(居中 contain,不裁切) -->
  <div class="hero-character absolute inset-0 z-[2]">
    {images.map((src, i) => {
      const srcset = responsiveSrcset(src);
      return (
        <img
          src={src}
          alt="符玄"
          class:list={["hero-char-img absolute inset-0 h-full w-full object-contain transition-opacity duration-[1200ms] ease-out", i === 0 ? "opacity-100" : "opacity-0"]}
          data-index={i}
          loading={i === 0 ? "eager" : "lazy"}
          fetchpriority={i === 0 ? "high" : "low"}
          decoding={i === 0 ? "auto" : "async"}
          {...(srcset ? { srcset, sizes: "80vw" } : {})}
        />
      );
    })}
  </div>

  <!-- 底部柔和遮罩(让文字可读) -->
  <div class="absolute inset-x-0 bottom-0 z-[3] h-2/3 bg-gradient-to-t from-[#2a1b3d]/60 via-[#2a1b3d]/10 to-transparent"></div>

  <!-- 文字内容 -->
  <div class="relative z-[4] container-prose px-4 text-center text-white">
    <p class="mb-3 animate-fade-in text-xs font-medium uppercase tracking-[0.4em] text-pink-200/80 [animation-delay:80ms] opacity-0">
      Brain of Liubo
    </p>
    <h1 class="animate-fade-up text-4xl font-bold font-serif tracking-tight drop-shadow-[0_2px_12px_rgba(255,122,171,0.4)] sm:text-5xl md:text-6xl [animation-delay:160ms] opacity-0">
      {SITE.heroTitle}
    </h1>
    <p class="mx-auto mt-5 max-w-xl animate-fade-up text-base text-white/85 [animation-delay:280ms] opacity-0 sm:text-lg">
      {SITE.heroSubtitle}
    </p>
    <p class="mx-auto mt-3 max-w-md animate-fade-up text-sm font-light italic text-pink-200/90 [animation-delay:400ms] opacity-0">
      「{SITE.heroMotto}」
    </p>
    <div class="mt-8 flex animate-fade-up flex-wrap items-center justify-center gap-3 [animation-delay:520ms] opacity-0">
      <a href="#latest" class="inline-flex items-center gap-2 rounded-full border border-white/25 bg-white/10 px-6 py-2.5 text-sm font-medium backdrop-blur-md transition-all duration-300 hover:scale-105 hover:border-pink-200/50 hover:bg-pink-200/15">
        走进这颗大脑
        <Icon name="chevron-down" size={16} />
      </a>
      <button
        id="pv-trigger"
        type="button"
        class="inline-flex items-center gap-2 rounded-full border border-pink-200/40 bg-pink-200/15 px-6 py-2.5 text-sm font-medium backdrop-blur-md transition-all duration-300 hover:scale-105 hover:border-pink-200/70 hover:bg-pink-200/25"
        aria-label={`播放${pv.title}`}
      >
        <span class="grid h-4 w-4 place-items-center rounded-full bg-pink-200/90 text-[#2a1b3d]">
          <svg viewBox="0 0 12 12" class="h-2.5 w-2.5" fill="currentColor"><path d="M3 1.5v9l7-4.5z"/></svg>
        </span>
        观看角色PV
      </button>
    </div>
  </div>

  <a href="#latest" class="absolute bottom-6 left-1/2 z-[4] -translate-x-1/2 text-white/60 animate-float-slow" aria-label="向下滚动">
    <Icon name="chevron-down" size={26} />
  </a>
</section>

<!-- 符玄角色PV 弹窗 -->
<div id="pv-modal" class="fixed inset-0 z-[200] hidden" role="dialog" aria-modal="true" aria-label={pv.title}>
  <div id="pv-backdrop" class="absolute inset-0 bg-black/70 backdrop-blur-sm opacity-0 transition-opacity duration-300"></div>
  <div class="relative flex h-full items-center justify-center p-4">
    <div id="pv-panel" class="relative w-full max-w-4xl translate-y-4 opacity-0 transition-all duration-300">
      <div class="mb-3 flex items-center justify-between text-white">
        <h2 class="text-sm font-medium tracking-wide text-pink-100/90">{pv.title}</h2>
        <button id="pv-close" class="grid h-9 w-9 place-items-center rounded-full border border-white/20 bg-white/10 text-white transition hover:bg-white/20" aria-label="关闭">
          <Icon name="close" size={18} />
        </button>
      </div>
      <div class="relative aspect-video w-full overflow-hidden rounded-2xl border border-white/15 bg-black shadow-2xl">
        <iframe
          id="pv-iframe"
          class="absolute inset-0 h-full w-full"
          src="about:blank"
          data-src={pvEmbedUrl}
          title={pv.title}
          frameborder="0"
          allow="autoplay; fullscreen; encrypted-media; picture-in-picture"
          allowfullscreen
          scrolling="no"
          referrerpolicy="no-referrer-when-downgrade"
        ></iframe>
      </div>
      <p class="mt-3 text-center text-xs text-white/50">
        原 PV © miHoYo / HoYoverse · <a href={`https://www.bilibili.com/video/${pv.bvid}/`} target="_blank" rel="noopener noreferrer" class="underline hover:text-pink-200">在 B站 查看</a>
      </p>
    </div>
  </div>
</div>

<style>
  .hero-gradient {
    background:
      radial-gradient(ellipse 80% 60% at 50% 20%, rgba(255, 200, 220, 0.35), transparent 60%),
      radial-gradient(ellipse 60% 50% at 80% 70%, rgba(180, 200, 255, 0.3), transparent 60%),
      linear-gradient(135deg, #2a1b3d 0%, #3d2a5c 35%, #4a2a55 65%, #2a1b3d 100%);
    background-size: 200% 200%;
    animation: gradient-pan 18s ease-in-out infinite;
  }
  @keyframes gradient-pan {
    0%, 100% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
  }

  .hero-char-img {
    filter: drop-shadow(0 4px 28px rgba(20, 8, 30, 0.18));
    animation: char-breathe 9s ease-in-out infinite;
    /* 边缘羽化:让立绘与背景渐变融为一体,无明显矩形边界 */
    -webkit-mask-image: radial-gradient(ellipse 78% 78% at 50% 48%, #000 55%, rgba(0,0,0,0.85) 72%, rgba(0,0,0,0) 100%);
    mask-image: radial-gradient(ellipse 78% 78% at 50% 48%, #000 55%, rgba(0,0,0,0.85) 72%, rgba(0,0,0,0) 100%);
  }
  @keyframes char-breathe {
    0%, 100% { transform: scale(1); }
    50% { transform: scale(1.015); }
  }

  .hero-bubble {
    width: 6px; height: 6px;
    background: radial-gradient(circle, rgba(255, 200, 230, 0.7), rgba(255, 200, 230, 0));
    animation: bubble-float calc(10s + var(--i) * 0.6s) ease-in-out infinite;
  }
  @keyframes bubble-float {
    0%, 100% { transform: translate(0, 0) scale(1); opacity: 0.4; }
    50% { transform: translate(calc(var(--i) * 4px - 24px), -30px) scale(1.3); opacity: 0.8; }
  }

  @media (prefers-reduced-motion: reduce) {
    .hero-gradient, .hero-char-img, .hero-bubble { animation: none !important; }
  }
</style>

<script is:inline define:vars={{ images, pvEmbedUrl }}>
  (function () {
    if (!images || images.length <= 1) return;
    const imgs = document.querySelectorAll('.hero-char-img');
    if (!imgs.length) return;
    // 仅预加载下一张,避免一次性拉全部图拖慢手机首屏
    const preload = (i) => {
      const im = new Image();
      im.src = imgs[i]?.currentSrc || imgs[i]?.src || images[i];
    };
    preload(1);
    let idx = 0;
    setInterval(() => {
      imgs[idx]?.classList.remove('opacity-100');
      imgs[idx]?.classList.add('opacity-0');
      idx = (idx + 1) % imgs.length;
      imgs[idx]?.classList.remove('opacity-0');
      imgs[idx]?.classList.add('opacity-100');
      // 提前预加载下一张
      preload((idx + 1) % images.length);
    }, 6500);
  })();

  // ===== 符玄角色PV 弹窗 =====
  (function () {
    const trigger = document.getElementById('pv-trigger');
    const modal = document.getElementById('pv-modal');
    const backdrop = document.getElementById('pv-backdrop');
    const panel = document.getElementById('pv-panel');
    const iframe = document.getElementById('pv-iframe');
    const closeBtn = document.getElementById('pv-close');
    if (!trigger || !modal || !iframe) return;

    const open = () => {
      modal.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
      // 仅在打开时设置 src,避免页面加载时即拉取 iframe
      const src = iframe.getAttribute('data-src');
      if (src && (iframe.src === '' || iframe.src === 'about:blank')) iframe.src = src;
      requestAnimationFrame(() => {
        backdrop?.classList.remove('opacity-0');
        panel?.classList.remove('translate-y-4', 'opacity-0');
      });
    };
    const close = () => {
      backdrop?.classList.add('opacity-0');
      panel?.classList.add('translate-y-4', 'opacity-0');
      // 重置到 about:blank 以停止播放(避免 B 站 player 持续在后台播放)
      iframe.src = 'about:blank';
      setTimeout(() => {
        modal.classList.add('hidden');
        document.body.style.overflow = '';
      }, 300);
    };

    trigger.addEventListener('click', open);
    closeBtn?.addEventListener('click', close);
    backdrop?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal.classList.contains('hidden')) close();
    });
  })();
</script>

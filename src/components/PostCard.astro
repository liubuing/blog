---
import type { Post } from '@/utils';
import { formatDate, getReadingTime } from '@/utils';
import Icon from './Icon.astro';

export interface Props {
  post: Post;
  featured?: boolean;
}
const { post, featured = false } = Astro.props;
const { title, description, pubDate, category, tags, cover } = post.data;
const url = `/blog/${post.id}/`;
const minutes = getReadingTime(post.body ?? '');
const coverImg = cover ?? '/images/fuxuan-portrait.png';
const isFullChar = !cover || cover.includes('fuxuan') || cover.includes('HoYoWiki');
---
<article class:list={["card group overflow-hidden", featured && "md:flex"]}>
  <a href={url} class:list={["block overflow-hidden", featured ? "md:w-1/2" : ""]}>
    <div class:list={["relative overflow-hidden", featured ? "aspect-[4/3] md:aspect-auto md:h-full" : "aspect-[16/10]", isFullChar && "bg-gradient-to-br from-[#3d2a5c] via-[#4a2a55] to-[#2a1b3d]"]}>
      <img
        src={coverImg}
        alt={title}
        loading="lazy"
        class:list={["transition-transform duration-700 group-hover:scale-[1.03]", isFullChar ? "h-full w-full object-contain p-3 drop-shadow-[0_4px_20px_rgba(0,0,0,0.3)]" : "h-full w-full object-cover"]}
      />
      <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100"></div>
      {featured && (
        <span class="absolute left-3 top-3 inline-flex items-center gap-1 rounded-full bg-pink-300/90 px-2.5 py-1 text-xs font-semibold text-[#2a1b3d] shadow-md backdrop-blur">
          <Icon name="pin" size={12} /> 置顶
        </span>
      )}
    </div>
  </a>
  <div class:list={["flex flex-col p-5", featured && "md:w-1/2 md:justify-center md:p-8"]}>
    <div class="mb-2 flex flex-wrap items-center gap-2 text-xs text-ink-light/50 dark:text-ink-dark/50">
      <a href={`/categories/${category}/`} class="tag-chip">{category}</a>
      <span class="flex items-center gap-1"><Icon name="calendar" size={13} />{formatDate(pubDate)}</span>
      <span class="flex items-center gap-1"><Icon name="clock" size={13} />{minutes} 分钟</span>
    </div>
    <h3 class:list={["font-serif font-bold transition-colors group-hover:text-accent", featured ? "text-2xl md:text-3xl" : "text-xl"]}>
      <a href={url}>{title}</a>
    </h3>
    <p class="mt-2 line-clamp-2 text-sm leading-relaxed text-ink-light/60 dark:text-ink-dark/60">
      {description}
    </p>
    <div class="mt-3 flex flex-wrap gap-1.5">
      {tags.slice(0, 3).map((t) => (
        <a href={`/tags/${t}/`} class="tag-chip">#{t}</a>
      ))}
    </div>
  </div>
</article>

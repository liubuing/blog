---
// 动态背景:浅色模式下漂浮的粉色光晕云,暗色模式保持静态深紫
---
<div class="bg-animated fixed inset-0 -z-10 overflow-hidden">
  <!-- 浅色模式:漂浮光晕 -->
  <div class="light-blobs">
    <span class="blob blob-1"></span>
    <span class="blob blob-2"></span>
    <span class="blob blob-3"></span>
    <span class="blob blob-4"></span>
    <span class="blob blob-5"></span>
  </div>
  <!-- 暗色模式:紫金动态光晕 + 闪烁金点 -->
  <div class="dark-stars">
    <span class="blob blob-d-1"></span>
    <span class="blob blob-d-2"></span>
    <span class="blob blob-d-3"></span>
    <span class="blob blob-d-4"></span>
    {Array.from({ length: 50 }).map((_, i) => (
      <span
        class="star"
        style={`left:${(i * 7.9) % 100}%; top:${(i * 13.3) % 100}%; animation-delay:${(i % 8) * 0.7}s; animation-duration:${3 + (i % 5)}s;`}
      ></span>
    ))}
  </div>
</div>

<style>
  .bg-animated {
    background: #FFF5F8;
  }
  html.dark .bg-animated {
    background: #1A1A2E;
  }

  /* ===== 浅色模式:漂浮粉色光晕 ===== */
  .light-blobs { display: block; }
  .dark-stars { display: none; }
  html.dark .light-blobs { display: none; }
  html.dark .dark-stars { display: block; }

  .blob {
    position: absolute;
    border-radius: 50%;
    filter: blur(70px);
    opacity: 0.45;
    will-change: transform;
  }
  /* 浅色:粉色光晕 */
  .blob-1 { width: 420px; height: 420px; background: #FFB6D5; top: -8%;  left: -6%;  animation: blob-float-1 22s ease-in-out infinite; }
  .blob-2 { width: 360px; height: 360px; background: #FFC8E0; top: 30%;  right: -8%; animation: blob-float-2 26s ease-in-out infinite; }
  .blob-3 { width: 480px; height: 480px; background: #FFD4E5; bottom: -12%; left: 20%; animation: blob-float-3 30s ease-in-out infinite; }
  .blob-4 { width: 300px; height: 300px; background: #FFE0EC; top: 55%; left: 8%;  animation: blob-float-4 24s ease-in-out infinite; }
  .blob-5 { width: 340px; height: 340px; background: #FFBEDB; top: 10%;  left: 48%; animation: blob-float-5 28s ease-in-out infinite; }

  /* 暗色:紫金光晕 */
  .blob-d-1 { width: 460px; height: 460px; background: #6B3FA0; top: -10%; left: -8%;  animation: blob-float-1 24s ease-in-out infinite; opacity: 0.35; }
  .blob-d-2 { width: 400px; height: 400px; background: #F5D76E; top: 25%;  right: -10%; animation: blob-float-2 28s ease-in-out infinite; opacity: 0.18; }
  .blob-d-3 { width: 520px; height: 520px; background: #4A2A7A; bottom: -14%; left: 18%; animation: blob-float-3 32s ease-in-out infinite; opacity: 0.4; }
  .blob-d-4 { width: 340px; height: 340px; background: #C99A2E; top: 50%; left: 55%; animation: blob-float-4 26s ease-in-out infinite; opacity: 0.15; }

  @keyframes blob-float-1 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(60px,80px) scale(1.1); } }
  @keyframes blob-float-2 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-80px,40px) scale(0.9); } }
  @keyframes blob-float-3 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(40px,-60px) scale(1.15); } }
  @keyframes blob-float-4 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(70px,-30px) scale(1.05); } }
  @keyframes blob-float-5 { 0%,100% { transform: translate(0,0) scale(1); } 50% { transform: translate(-50px,70px) scale(0.95); } }

  /* ===== 暗色模式:紫金呼吸星点 ===== */
  .star {
    position: absolute;
    width: 2px; height: 2px;
    border-radius: 50%;
    background: rgba(245, 215, 110, 0.8);
    box-shadow: 0 0 4px rgba(245, 215, 110, 0.6);
    animation: star-twinkle 4s ease-in-out infinite;
  }
  html:not(.dark) .star {
    background: rgba(255, 160, 200, 0.6);
    box-shadow: 0 0 3px rgba(255, 160, 200, 0.4);
  }
  @keyframes star-twinkle {
    0%, 100% { opacity: 0.2; transform: scale(1); }
    50% { opacity: 0.9; transform: scale(1.4); }
  }

  @media (prefers-reduced-motion: reduce) {
    .blob, .star { animation: none !important; }
  }
</style>
